# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS（前端开发地址）
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5273,http://localhost:5273

# 数据库（起步 SQLite；迁移 Postgres 时改为 postgres://user:pass@host:5432/dbname）
DATABASE_URL=sqlite

# ===== 大模型 =====
# 可选值：mock / zhipu / tongyi / baidu
AI_PROVIDER=mock

# 智谱 GLM
ZHIPU_API_KEY=
ZHIPU_CHAT_MODEL=glm-4-flash
ZHIPU_EMBED_MODEL=embedding-3

# 通义千问（阿里 DashScope）
TONGYI_API_KEY=
TONGYI_CHAT_MODEL=qwen-plus
TONGYI_EMBED_MODEL=text-embedding-v3
TONGYI_TTS_MODEL=cosyvoice-v1

# 百度文心
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
